<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=2.0, user-scalable=yes" />
    <title>{{.Slide.Title}} - Presentation</title>
    <meta name="description" content="{{.Slide.Title}} - Interactive presentation" />
    <meta name="author" content="Anshuman Biswas" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/static/favicon.svg" />
    
    <!-- Reveal.js CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/dist/reveal.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/dist/theme/white.css" id="theme">
    
    <!-- Code syntax highlighting -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/plugin/highlight/monokai.css">
    
    <!-- Custom styles -->
    <style>
        /* CSS Custom Properties from slide content */
        :root {
            --r-main-font-size: 30px;
            --r-block-margin: 16px;
            --r-heading-font: Inter, Segoe UI, Arial, sans-serif;
            --r-code-font: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
            --r-heading1-size: 2.0em;
            --r-heading2-size: 1.6em;
            --r-heading3-size: 1.35em;
            --slide-padding-x: 40px;
            --slide-padding-top: 60px;
            --slide-padding-bottom: 40px;
            --slide-padding-top-fullscreen: clamp(180px, 20vh, 420px);
            --slide-padding-top-current: var(--slide-padding-top);
            --slide-safe-area-top: 0px;
        }

        @supports (padding: env(safe-area-inset-top)) {
            :root {
                --slide-safe-area-top: env(safe-area-inset-top);
            }
        }

        /* Ensure full viewport usage and no clipping */
        html, body {
            width: 100% !important;
            height: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            overflow: hidden !important;
        }
        
        /* Critical slide content styles that were missing */
        .reveal .slides { 
            text-align: left; 
        }
        
        .reveal .slides section {
            max-width: 1100px !important;
            margin: 0 auto !important;
            padding: var(--slide-padding-top-current) var(--slide-padding-x) var(--slide-padding-bottom) var(--slide-padding-x) !important;
            padding-top: calc(var(--slide-padding-top-current) + var(--slide-safe-area-top)) !important;
            overflow-y: auto !important;
            overflow-x: hidden !important;
            box-sizing: border-box !important;
        }

        /* PPTX imported slides use absolute positioning - remove padding/width constraints */
        .reveal .slides section.pptx-slide {
            padding: 0 !important;
            max-width: 100% !important;
            width: 100% !important;
            height: 100% !important;
            overflow: hidden !important;
        }

        .reveal .slides section.pptx-slide p,
        .reveal .slides section.pptx-slide h1,
        .reveal .slides section.pptx-slide h3,
        .reveal .slides section.pptx-slide li {
            margin: 0;
            line-height: 1.3;
        }

        @media (max-height: 820px) {
            :root {
                --slide-padding-top-fullscreen: clamp(130px, 18vh, 260px);
            }
        }

        @media (max-width: 900px) {
            :root {
                --slide-padding-x: 28px;
                --slide-padding-top: 40px;
                --slide-padding-bottom: 32px;
                --slide-padding-top-fullscreen: clamp(120px, 20vh, 240px);
            }
        }

        @media (max-width: 640px) {
            :root {
                --slide-padding-x: 20px;
            }
        }

        /* Ensure slides container uses flexbox for proper centering */
        .reveal .slides {
            display: flex !important;
            align-items: flex-start !important;
            justify-content: center !important;
        }
        
        /* Typography styles from slide content */
        .reveal h1, .reveal h2, .reveal h3 { 
            color: #111; 
            line-height: 1.08; 
            letter-spacing: -0.01em; 
        }
        
        .subtitle { 
            font-size: 1.05rem; 
            color: #333; 
            margin-top: .4rem; 
        }
        
        .byline { 
            font-size: .95rem; 
            color: #555; 
        }
        
        .footnote { 
            font-size: .8rem; 
            color: #666; 
        }
        
        .mono { 
            font-family: var(--r-code-font); 
        }
        
        .pill { 
            display: inline-block; 
            border: 1px solid #111; 
            border-radius: 999px; 
            padding: .2rem .6rem; 
            margin-right: .4rem; 
        }
        
        .quote { 
            font-size: 1.1rem; 
            color: #222; 
            border-left: 4px solid #111; 
            padding-left: .8rem; 
        }
        
        /* Grid layouts from slide content */
        .two-col { 
            display: grid; 
            grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr); 
            gap: 2rem; 
            align-items: center; 
        }
        
        .grid-2 { 
            display: grid; 
            grid-template-columns: repeat(2, minmax(0, 1fr)); 
            gap: 2rem; 
        }
        
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1.2rem;
            max-width: 100%;
            box-sizing: border-box;
        }

        .grid-3 > div {
            min-width: 0; /* prevent grid blowout */
            box-sizing: border-box;
        }
        
        .reveal pre code { 
            font-size: .82em; 
            line-height: 1.35; 
        }
        
        .reveal pre { 
            box-shadow: none; 
        }
        
        .tight { 
            margin-top: .6rem; 
        }
        
        .reveal .slides svg {
            display: block;
            width: 100%;
            height: auto;
            max-width: 100%;
            max-height: 56vh;
            margin: .4rem auto 0;
            box-sizing: border-box;
        }
        
        footer.tiny { 
            position: fixed; 
            bottom: 8px; 
            right: 16px; 
            font-size: .72rem; 
            color: #666; 
        }
        
        /* Allow slide content to define its own styling - only apply minimal overrides */
        .reveal .slides section.center {
            text-align: center;
        }
        
        .reveal .controls {
            color: #2563eb;
        }
        
        .reveal .progress {
            color: #2563eb;
        }
        
        .reveal a {
            color: #2563eb;
        }
        
        .reveal a:hover {
            color: #1d4ed8;
        }
        
        /* Custom navigation overlay */
        .presentation-nav {
            position: fixed;
            top: calc(20px + var(--slide-safe-area-top));
            right: 20px;
            z-index: 100;
            display: flex;
            gap: 10px;
            align-items: center;
        }
        
        .nav-btn {
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            color: #374151;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        
        .nav-btn:hover {
            background: rgba(255, 255, 255, 1);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            color: #2563eb;
        }
        
        .nav-btn svg {
            width: 16px;
            height: 16px;
        }
        
        /* Hide navigation on print */
        @media print {
            .presentation-nav {
                display: none;
            }
        }
        
        /* Dark theme adjustments */
        @media (prefers-color-scheme: dark) {
            .nav-btn {
                background: rgba(30, 41, 59, 0.9);
                border-color: #475569;
                color: #e2e8f0;
            }
            
            .nav-btn:hover {
                background: rgba(30, 41, 59, 1);
                color: #60a5fa;
            }
        }

        /* Ensure slide content doesn't get cut off - preserve slide content's own styling */
        .reveal .slides {
            width: 100% !important;
            height: 100% !important;
        }
        
        /* Ensure the reveal container can accommodate the slide content's max-width */
        .reveal {
            width: 100% !important;
            height: 100% !important;
        }

        /* Extra top padding in fullscreen mode to prevent cutoff */
        body.is-fullscreen,
        .reveal.full-screen,
        html:fullscreen,
        body:fullscreen,
        .reveal:fullscreen {
            --slide-padding-top-current: var(--slide-padding-top-fullscreen);
        }

        :-webkit-full-screen {
            --slide-padding-top-current: var(--slide-padding-top-fullscreen);
        }

        :-moz-full-screen {
            --slide-padding-top-current: var(--slide-padding-top-fullscreen);
        }

        :-ms-fullscreen {
            --slide-padding-top-current: var(--slide-padding-top-fullscreen);
        }
    </style>
</head>

<body>
    <!-- Custom Navigation -->
    <div class="presentation-nav">
        {{if .Slide.Contributors}}
        <div style="display:flex;gap:-4px;align-items:center;margin-right:8px">
            {{range .Slide.Contributors}}
            <span title="{{.FullName}}" style="display:inline-block;width:28px;height:28px;border-radius:50%;overflow:hidden;border:2px solid #fff;margin-left:-4px;background:#e2e8f0">
                {{if .AvatarURL}}<img src="{{thumbURL .AvatarURL}}" alt="{{.Username}}" width="28" height="28" style="width:100%;height:100%;object-fit:cover">{{else}}<span style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;font-size:12px;font-weight:600;color:#6b7280">{{slice .Username 0 1}}</span>{{end}}
            </span>
            {{end}}
        </div>
        {{end}}
        {{if .LoggedIn}}
            {{if .UserPermissions.CanEditSlides}}
                <a href="/admin/slides/{{.Slide.ID}}/edit" class="nav-btn" title="Edit Slide">
                    {{icon "edit" "w-4 h-4"}}
                    Edit
                </a>
            {{end}}
        {{end}}
        <a href="/slides" class="nav-btn" title="Back to Slides">
            {{icon "chevron-left" "w-4 h-4"}}
            Back
        </a>
        <button id="fullscreen-btn" class="nav-btn" title="Toggle Fullscreen">
            {{icon "fullscreen" "w-4 h-4"}}
            Fullscreen
        </button>
    </div>
    
    <div class="reveal">
        <div class="slides">
            {{.Slide.ContentHTML}}
        </div>
    </div>

    <!-- Load Reveal.js library -->
    <script src="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/dist/reveal.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/plugin/notes/notes.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/plugin/highlight/highlight.js"></script>
    <!-- Mermaid.js for diagrams -->
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
    <!-- go-draw embed script for interactive canvas drawings -->
    <script src="/draw/static/embed.js"></script>

    <!-- Initialize Reveal.js -->
    <script>
        Reveal.initialize({
            width: 1280,
            height: 800,
            margin: 0.08,
            minScale: 0.2,
            maxScale: 1.5,
            hash: true,
            controls: true,
            progress: true,
            slideNumber: true,
            center: false,
            transition: 'fade',
            transitionSpeed: 'default',
            autoAnimateEasing: 'ease-out',
            plugins: [ RevealNotes, RevealHighlight ]
        });

        // Initialize Mermaid diagrams
        if (typeof mermaid !== 'undefined') {
            mermaid.initialize({ startOnLoad: false, theme: 'default' });
            mermaid.run({ querySelector: '.mermaid' });
        }
    </script>

    <script>
        // Fullscreen functionality
        document.getElementById('fullscreen-btn').addEventListener('click', function() {
            const exitFullscreen = () => {
                if (document.exitFullscreen) {
                    document.exitFullscreen();
                } else if (document.webkitExitFullscreen) {
                    document.webkitExitFullscreen();
                } else if (document.mozCancelFullScreen) {
                    document.mozCancelFullScreen();
                } else if (document.msExitFullscreen) {
                    document.msExitFullscreen();
                }
            };

            const requestFullscreen = (element) => {
                if (element.requestFullscreen) {
                    element.requestFullscreen();
                } else if (element.webkitRequestFullscreen) {
                    element.webkitRequestFullscreen();
                } else if (element.mozRequestFullScreen) {
                    element.mozRequestFullScreen();
                } else if (element.msRequestFullscreen) {
                    element.msRequestFullscreen();
                }
            };

            const target = document.documentElement;
            if (
                document.fullscreenElement ||
                document.webkitFullscreenElement ||
                document.mozFullScreenElement ||
                document.msFullscreenElement
            ) {
                exitFullscreen();
            } else {
                requestFullscreen(target);
            }
        });

        // Wait for slide content to initialize Reveal.js, then add our custom functionality
        document.addEventListener('DOMContentLoaded', function() {
            // Wait a bit for Reveal.js to be initialized by the slide content
            setTimeout(function() {
                if (window.Reveal) {
                    // Update fullscreen button on fullscreen change
                    const fullscreenEvents = ['fullscreenchange', 'webkitfullscreenchange', 'mozfullscreenchange', 'MSFullscreenChange'];
                    const updateFullscreenState = () => {
                        const btn = document.getElementById('fullscreen-btn');
                        if (!btn) {
                            return;
                        }

                        const svg = btn.querySelector('svg path');
                        const isFullscreen = Boolean(
                            document.fullscreenElement ||
                            document.webkitFullscreenElement ||
                            document.mozFullScreenElement ||
                            document.msFullscreenElement
                        );

                        document.body.classList.toggle('is-fullscreen', isFullscreen);

                        if (svg) {
                            if (isFullscreen) {
                                svg.setAttribute('d', 'M8 3a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1zM8 21a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1zM3 8a1 1 0 011-1h2a1 1 0 110 2H4a1 1 0 01-1-1zM21 8a1 1 0 011-1h2a1 1 0 110 2h-2a1 1 0 01-1-1z');
                                btn.title = 'Exit Fullscreen';
                            } else {
                                svg.setAttribute('d', 'M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4');
                                btn.title = 'Toggle Fullscreen';
                            }
                        }
                    };

                    fullscreenEvents.forEach(eventName => {
                        document.addEventListener(eventName, updateFullscreenState);
                    });

                    updateFullscreenState();

                    // Analytics - track slide views
                    if (window.gtag) {
                        gtag('event', 'slide_view', {
                            'slide_title': '{{.Slide.Title}}',
                            'slide_slug': '{{.Slide.Slug}}'
                        });
                    }

                    // Track slide changes for analytics
                    Reveal.on('slidechanged', function(event) {
                        if (window.gtag) {
                            gtag('event', 'slide_change', {
                                'slide_title': '{{.Slide.Title}}',
                                'slide_index': event.indexh + '-' + event.indexv
                            });
                        }
                    });
                }
            }, 100);
        });
    </script>
</body>
</html>
