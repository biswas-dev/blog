<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=2.0, user-scalable=yes" />
    <title>{{.Slide.Title}} - Presentation</title>
    <meta name="description" content="{{.Slide.Title}} - Interactive presentation" />
    <meta name="author" content="Anshuman Biswas" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/static/favicon.svg" />
    
    <!-- Reveal.js CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/dist/reveal.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/dist/theme/white.css" id="theme">
    
    <!-- Code syntax highlighting -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/plugin/highlight/monokai.css">
    
    <!-- Custom styles -->
    <style>
        /* CSS Custom Properties from slide content */
        :root {
            --r-main-font-size: 30px;
            --r-block-margin: 16px;
            --r-heading-font: Inter, Segoe UI, Arial, sans-serif;
            --r-code-font: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
            --r-heading1-size: 2.0em;
            --r-heading2-size: 1.6em;
            --r-heading3-size: 1.35em;
        }

        /* Ensure full viewport usage and no clipping */
        html, body {
            width: 100% !important;
            height: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            overflow: hidden !important;
        }
        
        /* Critical slide content styles that were missing */
        .reveal .slides { 
            text-align: left; 
        }
        
        .reveal .slides section {
            max-width: 1100px !important;
            margin: 0 auto !important;
            padding: 60px 40px 40px 40px !important;
            overflow: visible !important;
            box-sizing: border-box !important;
        }

        /* Ensure slides container uses flexbox for proper centering */
        .reveal .slides {
            display: flex !important;
            align-items: flex-start !important;
            justify-content: center !important;
        }
        
        /* Typography styles from slide content */
        .reveal h1, .reveal h2, .reveal h3 { 
            color: #111; 
            line-height: 1.08; 
            letter-spacing: -0.01em; 
        }
        
        .subtitle { 
            font-size: 1.05rem; 
            color: #333; 
            margin-top: .4rem; 
        }
        
        .byline { 
            font-size: .95rem; 
            color: #555; 
        }
        
        .footnote { 
            font-size: .8rem; 
            color: #666; 
        }
        
        .mono { 
            font-family: var(--r-code-font); 
        }
        
        .pill { 
            display: inline-block; 
            border: 1px solid #111; 
            border-radius: 999px; 
            padding: .2rem .6rem; 
            margin-right: .4rem; 
        }
        
        .quote { 
            font-size: 1.1rem; 
            color: #222; 
            border-left: 4px solid #111; 
            padding-left: .8rem; 
        }
        
        /* Grid layouts from slide content */
        .two-col { 
            display: grid; 
            grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr); 
            gap: 2rem; 
            align-items: center; 
        }
        
        .grid-2 { 
            display: grid; 
            grid-template-columns: repeat(2, minmax(0, 1fr)); 
            gap: 2rem; 
        }
        
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1.2rem;
            max-width: 100%;
            box-sizing: border-box;
        }

        .grid-3 > div {
            min-width: 0; /* prevent grid blowout */
            box-sizing: border-box;
        }
        
        .reveal pre code { 
            font-size: .82em; 
            line-height: 1.35; 
        }
        
        .reveal pre { 
            box-shadow: none; 
        }
        
        .tight { 
            margin-top: .6rem; 
        }
        
        .reveal .slides svg {
            display: block;
            width: 100%;
            height: auto;
            max-width: 100%;
            max-height: 56vh;
            margin: .4rem auto 0;
            box-sizing: border-box;
        }
        
        /* Responsive adjustments for smaller screens */
        @media (max-width: 900px) {
            .reveal .slides section { 
                padding: 0 36px 48px 36px !important; 
            }
        }
        
        footer.tiny { 
            position: fixed; 
            bottom: 8px; 
            right: 16px; 
            font-size: .72rem; 
            color: #666; 
        }
        
        /* Allow slide content to define its own styling - only apply minimal overrides */
        .reveal .slides section.center {
            text-align: center;
        }
        
        .reveal .controls {
            color: #2563eb;
        }
        
        .reveal .progress {
            color: #2563eb;
        }
        
        .reveal a {
            color: #2563eb;
        }
        
        .reveal a:hover {
            color: #1d4ed8;
        }
        
        /* Custom navigation overlay */
        .presentation-nav {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 100;
            display: flex;
            gap: 10px;
            align-items: center;
        }
        
        .nav-btn {
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            color: #374151;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        
        .nav-btn:hover {
            background: rgba(255, 255, 255, 1);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            color: #2563eb;
        }
        
        .nav-btn svg {
            width: 16px;
            height: 16px;
        }
        
        /* Hide navigation on print */
        @media print {
            .presentation-nav {
                display: none;
            }
        }
        
        /* Dark theme adjustments */
        @media (prefers-color-scheme: dark) {
            .nav-btn {
                background: rgba(30, 41, 59, 0.9);
                border-color: #475569;
                color: #e2e8f0;
            }
            
            .nav-btn:hover {
                background: rgba(30, 41, 59, 1);
                color: #60a5fa;
            }
        }

        /* Ensure slide content doesn't get cut off - preserve slide content's own styling */
        .reveal .slides {
            width: 100% !important;
            height: 100% !important;
        }
        
        /* Ensure the reveal container can accommodate the slide content's max-width */
        .reveal {
            width: 100% !important;
            height: 100% !important;
        }

        /* Responsive padding for smaller screens */
        @media (max-width: 900px) {
            .reveal .slides section {
                padding: 0 20px 30px 20px !important;
            }
        }
    </style>
</head>

<body>
    <!-- Custom Navigation -->
    <div class="presentation-nav">
        {{if .LoggedIn}}
            {{if .IsAdmin}}
                <a href="/admin/slides/{{.Slide.ID}}/edit" class="nav-btn" title="Edit Slide">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Edit
                </a>
            {{end}}
        {{end}}
        <a href="/slides" class="nav-btn" title="Back to Slides">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Back
        </a>
        <button id="fullscreen-btn" class="nav-btn" title="Toggle Fullscreen">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
            </svg>
            Fullscreen
        </button>
    </div>
    
    <div class="reveal">
        <div class="slides">
            {{.Slide.ContentHTML}}
        </div>
    </div>

    <!-- Load Reveal.js library -->
    <script src="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/dist/reveal.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/plugin/notes/notes.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/reveal.js@4.3.1/plugin/highlight/highlight.js"></script>

    <!-- Initialize Reveal.js -->
    <script>
        Reveal.initialize({
            width: 1280,
            height: 800,
            margin: 0.08,
            minScale: 0.2,
            maxScale: 1.5,
            hash: true,
            controls: true,
            progress: true,
            slideNumber: true,
            center: false,
            transition: 'fade',
            transitionSpeed: 'default',
            autoAnimateEasing: 'ease-out',
            plugins: [ RevealNotes, RevealHighlight ]
        });
    </script>

    <script>
        // Fullscreen functionality
        document.getElementById('fullscreen-btn').addEventListener('click', function() {
            if (document.fullscreenElement) {
                document.exitFullscreen();
            } else {
                document.documentElement.requestFullscreen();
            }
        });

        // Wait for slide content to initialize Reveal.js, then add our custom functionality
        document.addEventListener('DOMContentLoaded', function() {
            // Wait a bit for Reveal.js to be initialized by the slide content
            setTimeout(function() {
                if (window.Reveal) {
                    // Update fullscreen button on fullscreen change
                    document.addEventListener('fullscreenchange', function() {
                        const btn = document.getElementById('fullscreen-btn');
                        const svg = btn.querySelector('svg path');
                        if (document.fullscreenElement) {
                            svg.setAttribute('d', 'M8 3a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1zM8 21a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1zM3 8a1 1 0 011-1h2a1 1 0 110 2H4a1 1 0 01-1-1zM21 8a1 1 0 011-1h2a1 1 0 110 2h-2a1 1 0 01-1-1z');
                            btn.title = 'Exit Fullscreen';
                        } else {
                            svg.setAttribute('d', 'M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4');
                            btn.title = 'Toggle Fullscreen';
                        }
                    });

                    // Analytics - track slide views
                    if (window.gtag) {
                        gtag('event', 'slide_view', {
                            'slide_title': '{{.Slide.Title}}',
                            'slide_slug': '{{.Slide.Slug}}'
                        });
                    }

                    // Track slide changes for analytics
                    Reveal.on('slidechanged', function(event) {
                        if (window.gtag) {
                            gtag('event', 'slide_change', {
                                'slide_title': '{{.Slide.Title}}',
                                'slide_index': event.indexh + '-' + event.indexv
                            });
                        }
                    });
                }
            }, 100);
        });
    </script>
</body>
</html>
