{{template "modern-header" .}}

<section class="user-posts-section">
    <div class="user-header mb-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-2">
            {{if .UserPermissions.CanEditPosts}}My Posts & Comments{{else}}My Activity{{end}}
        </h1>

        <!-- Stats row (visible to all) -->
        <div class="activity-stats">
            {{if .UserPermissions.CanEditPosts}}
            <div class="activity-stat">
                <span class="activity-stat-num">{{len .Posts.Posts}}</span>
                <span class="activity-stat-label">Posts</span>
            </div>
            {{end}}
            <div class="activity-stat">
                <span class="activity-stat-num">{{len .UserComments}}</span>
                <span class="activity-stat-label">Comments</span>
            </div>
            <div class="activity-stat">
                <span class="activity-stat-num">{{len .UserAnnotations}}</span>
                <span class="activity-stat-label">Annotations</span>
            </div>
        </div>
    </div>

    {{if .UserPermissions.CanEditPosts}}
    <!-- Posts Management Section (editors/admins only) -->
    <div class="section-block mb-10">
        <div class="section-title-row mb-4">
            <h2 class="section-title">My Posts</h2>
            <a href="/admin/posts/new" class="btn btn-primary btn-sm">
                {{icon "plus" "w-4 h-4"}}
                New Post
            </a>
        </div>

        <!-- Stats Overview -->
        <div class="stats-grid mb-6">
            <div class="stat-card">
                <div class="stat-icon published">
                    {{icon "check-circle" "w-6 h-6"}}
                </div>
                <div class="stat-content">
                    <div class="stat-number" id="published-count">0</div>
                    <div class="stat-label">Published</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon draft">
                    {{icon "x-circle" "w-6 h-6"}}
                </div>
                <div class="stat-content">
                    <div class="stat-number" id="draft-count">0</div>
                    <div class="stat-label">Drafts</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon total">
                    {{icon "document" "w-6 h-6"}}
                </div>
                <div class="stat-content">
                    <div class="stat-number">{{len .Posts.Posts}}</div>
                    <div class="stat-label">Total Posts</div>
                </div>
            </div>
        </div>

        <!-- Posts List -->
        <div class="posts-list">
            {{if .Posts.Posts}}
                {{range .Posts.Posts}}
                <article class="post-item">
                    <div class="post-main">
                        <div class="post-header">
                            <h3 class="post-title">
                                <a href="/blog/{{.Slug}}" class="post-link">{{.Title}}</a>
                            </h3>
                            <div class="post-meta">
                                <span class="post-date">
                                    {{icon "calendar" "w-4 h-4"}}
                                    <time class="relative-time" datetime="{{.CreatedAt}}">{{.PublicationDate}}</time>
                                </span>
                                <span class="post-status {{if .IsPublished}}published{{else}}draft{{end}}">
                                    {{if .IsPublished}}
                                        {{icon "check-circle" "w-4 h-4 text-green-500"}}
                                        Published
                                    {{else}}
                                        {{icon "x-circle" "w-4 h-4 text-yellow-500"}}
                                        Draft
                                    {{end}}
                                </span>
                            </div>
                        </div>
                        <div class="post-content">
                            <p class="post-excerpt">
                                {{if gt (len .Content) 200}}
                                    {{slice .Content 0 200}}...
                                {{else}}
                                    {{.Content}}
                                {{end}}
                            </p>
                        </div>
                    </div>
                    <div class="post-actions">
                        <a href="/blog/{{.Slug}}" class="action-btn view">
                            {{icon "eye" "w-4 h-4"}}
                            View
                        </a>
                        <a href="/admin/posts/{{.ID}}/edit" class="action-btn edit">
                            {{icon "edit" "w-4 h-4"}}
                            Edit
                        </a>
                    </div>
                </article>
                {{end}}
            {{else}}
                <div class="no-posts">
                    <div class="no-posts-content">
                        {{icon "document" "w-16 h-16 mx-auto text-gray-400 dark:text-gray-600 mb-4"}}
                        <h3 class="text-xl font-semibold mb-2 text-gray-900 dark:text-gray-100">No posts yet</h3>
                        <p class="text-gray-600 dark:text-gray-400 mb-6">You haven't created any posts yet. Start writing your first post!</p>
                        <a href="/admin/posts/new" class="btn btn-primary">
                            {{icon "plus" "w-4 h-4"}}
                            Write First Post
                        </a>
                    </div>
                </div>
            {{end}}
        </div>
    </div>
    {{end}}

    <!-- My Comments Section (visible to all) -->
    <div class="section-block mb-10">
        <div class="section-title-row mb-4">
            <h2 class="section-title">My Comments</h2>
            <span class="section-count">{{len .UserComments}}</span>
        </div>
        {{if .UserComments}}
        <div class="activity-list">
            {{range .UserComments}}
            <div class="activity-item">
                <div class="activity-main">
                    <a href="/blog/{{.PostSlug}}#comment-{{.CommentID}}" class="activity-post-title">{{.PostTitle}}</a>
                    <p class="activity-content">{{if gt (len .Content) 300}}{{slice .Content 0 300}}...{{else}}{{.Content}}{{end}}</p>
                </div>
                <div class="activity-meta">
                    <time class="activity-date relative-time" datetime="{{.CommentDate.Format "2006-01-02T15:04:05Z07:00"}}">{{.CommentDate.Format "Jan 2, 2006"}}</time>
                </div>
            </div>
            {{end}}
        </div>
        {{else}}
        <div class="no-activity">
            {{icon "dots-horizontal" "w-10 h-10 mx-auto text-gray-300 dark:text-gray-600 mb-3"}}
            <p class="text-gray-500 dark:text-gray-400 text-sm">No comments yet. Join the discussion on a blog post!</p>
        </div>
        {{end}}
    </div>

    <!-- My Annotations Section (visible to all) -->
    <div class="section-block">
        <div class="section-title-row mb-4">
            <h2 class="section-title">My Annotations</h2>
            <span class="section-count">{{len .UserAnnotations}}</span>
        </div>
        {{if .UserAnnotations}}
        <div class="activity-list">
            {{range .UserAnnotations}}
            <div class="activity-item">
                <div class="activity-main">
                    <a href="/blog/{{.PostSlug}}" class="activity-post-title">{{.PostTitle}}</a>
                    <p class="activity-content annotation-quote">
                        <span class="annotation-color-dot" style="background:{{if eq .Color "yellow"}}#fbbf24{{else if eq .Color "green"}}#34d399{{else if eq .Color "blue"}}#60a5fa{{else if eq .Color "pink"}}#f472b6{{else if eq .Color "purple"}}#a78bfa{{else}}#fbbf24{{end}}"></span>
                        {{if gt (len .SelectedText) 200}}{{slice .SelectedText 0 200}}...{{else}}{{.SelectedText}}{{end}}
                    </p>
                </div>
                <div class="activity-meta">
                    <time class="activity-date relative-time" datetime="{{.CreatedAt.Format "2006-01-02T15:04:05Z07:00"}}">{{.CreatedAt.Format "Jan 2, 2006"}}</time>
                </div>
            </div>
            {{end}}
        </div>
        {{else}}
        <div class="no-activity">
            {{icon "chat" "w-10 h-10 mx-auto text-gray-300 dark:text-gray-600 mb-3"}}
            <p class="text-gray-500 dark:text-gray-400 text-sm">No annotations yet. Highlight text on a blog post to annotate!</p>
        </div>
        {{end}}
    </div>
</section>

<style>
.user-posts-section { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }

/* Activity stats strip */
.activity-stats { display: flex; gap: 2rem; margin-top: 0.75rem; }
.activity-stat { display: flex; align-items: baseline; gap: 0.4rem; }
.activity-stat-num { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); }
.activity-stat-label { font-size: 0.875rem; color: var(--text-secondary); }

/* Section blocks */
.section-block { background: var(--surface); border: 1px solid var(--border-light); border-radius: var(--radius); padding: 1.5rem; }
.section-title-row { display: flex; align-items: center; justify-content: space-between; }
.section-title { font-size: 1.125rem; font-weight: 700; color: var(--text-primary); }
.section-count { font-size: 0.875rem; font-weight: 600; background: var(--bg-tertiary); color: var(--text-secondary); padding: 0.2rem 0.6rem; border-radius: 999px; }

/* Posts management stats */
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; }
.stat-card { background: var(--bg-secondary); border: 1px solid var(--border-light); border-radius: var(--radius); padding: 1rem; display: flex; align-items: center; gap: 0.75rem; }
.stat-icon { width: 2.5rem; height: 2.5rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; flex-shrink: 0; }
.stat-icon.published { background: #10b981; }
.stat-icon.draft { background: #f59e0b; }
.stat-icon.total { background: var(--accent); }
.stat-content { flex: 1; }
.stat-number { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); line-height: 1; }
.stat-label { color: var(--text-secondary); font-size: 0.8rem; font-weight: 500; }

/* Posts list */
.posts-list { display: flex; flex-direction: column; gap: 0.75rem; }
.post-item { background: var(--bg-secondary); border: 1px solid var(--border-light); border-radius: var(--radius); padding: 1.25rem; display: flex; align-items: center; gap: 1.5rem; transition: border-color 0.2s; }
.post-item:hover { border-color: var(--border); }
.post-main { flex: 1; }
.post-header { margin-bottom: 0.5rem; }
.post-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.35rem; }
.post-link { color: var(--text-primary); text-decoration: none; transition: color 0.2s; }
.post-link:hover { color: var(--accent); }
.post-meta { display: flex; flex-wrap: wrap; gap: 1rem; font-size: 0.8rem; color: var(--text-tertiary); }
.post-date, .post-status { display: flex; align-items: center; gap: 0.25rem; }
.post-status.published { color: #10b981; }
.post-status.draft { color: #f59e0b; }
.post-excerpt { color: var(--text-secondary); font-size: 0.875rem; line-height: 1.5; }
.post-actions { display: flex; gap: 0.5rem; flex-shrink: 0; }
.action-btn { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.4rem 0.65rem; border-radius: 0.25rem; font-size: 0.8rem; font-weight: 500; text-decoration: none; border: none; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
.action-btn.view { background: var(--bg-tertiary); color: var(--text-primary); }
.action-btn.view:hover { background: var(--accent); color: white; }
.action-btn.edit { background: var(--accent); color: white; }
.action-btn.edit:hover { background: var(--accent-hover); }
.no-posts { text-align: center; padding: 2.5rem 1.5rem; }

/* Activity list (comments + annotations) */
.activity-list { display: flex; flex-direction: column; gap: 0; }
.activity-item { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; padding: 0.875rem 0; border-bottom: 1px solid var(--border-light); }
.activity-item:last-child { border-bottom: none; padding-bottom: 0; }
.activity-item:first-child { padding-top: 0; }
.activity-main { flex: 1; min-width: 0; }
.activity-post-title { font-size: 0.875rem; font-weight: 600; color: var(--accent); text-decoration: none; display: block; margin-bottom: 0.3rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.activity-post-title:hover { text-decoration: underline; }
.activity-content { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.5; margin: 0; }
.activity-meta { flex-shrink: 0; }
.activity-date { font-size: 0.75rem; color: var(--text-tertiary); white-space: nowrap; }

/* Annotation quote style */
.annotation-quote { display: flex; align-items: flex-start; gap: 0.5rem; font-style: italic; }
.annotation-color-dot { display: inline-block; width: 0.6rem; height: 0.6rem; border-radius: 50%; flex-shrink: 0; margin-top: 0.35rem; }

.no-activity { text-align: center; padding: 1.5rem 1rem; }

.btn-sm { padding: 0.35rem 0.75rem; font-size: 0.875rem; }

@media (max-width: 768px) {
    .post-item { flex-direction: column; gap: 0.75rem; align-items: flex-start; }
    .post-actions { width: 100%; justify-content: flex-end; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .activity-stats { gap: 1.25rem; }
}
</style>

<script>
{{if .UserPermissions.CanEditPosts}}
const postsData = [
    {{range .Posts.Posts}}
    { isPublished: {{.IsPublished}} },
    {{end}}
];

document.addEventListener('DOMContentLoaded', () => {
    let published = 0, drafts = 0;
    postsData.forEach(p => { if (p.isPublished) published++; else drafts++; });
    const pc = document.getElementById('published-count');
    const dc = document.getElementById('draft-count');
    if (pc) pc.textContent = published;
    if (dc) dc.textContent = drafts;
    convertToRelativeTime();
});
{{else}}
document.addEventListener('DOMContentLoaded', () => { convertToRelativeTime(); });
{{end}}
</script>

{{template "modern-footer" .}}
