}

/* Image management styling */

/* Image selection checkboxes */
.image-checkbox-container {
  position: relative;
}

.image-checkbox {
  position: absolute;
  top: 8px;
  left: 8px;
  z-index: 10;
  width: 20px;
  height: 20px;
  cursor: pointer;
}

.image-checkbox-label {
  display: block;
  cursor: pointer;
  position: relative;
}

.existing-image-item:has(.image-checkbox:checked) {
  ring: 3px solid #3b82f6;
  border-color: #3b82f6;
}

.existing-image-item {
  position: relative;
  border: 2px solid transparent;
  border-radius: 8px;
  transition: all 0.2s;
}

/* Button styles */
.btn-sm {
  padding: 4px 12px;
  font-size: 12px;
}

.btn-danger {
  background-color: #dc2626;
  color: white;
}

.btn-danger:hover {
  background-color: #b91c1c;
}

